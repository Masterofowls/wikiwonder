# Django
DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1
# Local dev fallback (tests use sqlite by default)
DATABASE_URL=sqlite:///db.sqlite3

# Supabase Postgres (production / shared wiki storage)
# URL-encode special characters in the password (* → %2A, ^ → %5E)
# DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Supabase project (optional — reserved for future integrations)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# django-allauth (verification requires SMTP; defaults to none without EMAIL_HOST)
ACCOUNT_EMAIL_VERIFICATION=optional

# Email (optional — omit EMAIL_HOST to use console backend in dev)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com

# Cerebras AI — get key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Site
SITE_NAME=WikiWonder
SITE_URL=http://localhost:9000
SEO_SITE_KEYWORDS=wiki, knowledge base, encyclopedia, WikiWonder, articles
SEO_SITE_DESCRIPTION=WikiWonder is a free wiki and knowledge base for articles, shared links, and collaborative notes. Browse encyclopedia-style pages, bookmarks, and imports.
META_SITE_PROTOCOL=http
META_SITE_DOMAIN=localhost:9000

# PWA
PWA_APP_NAME=WikiWonder
PWA_APP_DESCRIPTION=WikiWonder
