# Django
DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1
# Local dev fallback (tests use sqlite by default)
DATABASE_URL=sqlite:///db.sqlite3

# Supabase Postgres (production / shared wiki storage)
# URL-encode special characters in the password (* → %2A, ^ → %5E)
# DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Supabase project (optional — reserved for future integrations)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# django-allauth
ACCOUNT_EMAIL_VERIFICATION=optional

# Cerebras AI — get key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Site
SITE_NAME=WikiWonder
SITE_URL=http://localhost:9000

# PWA
PWA_APP_NAME=WikiWonder
PWA_APP_DESCRIPTION=WikiWonder
